# Environment variables template
# Copy this file to .env and fill in your actual API keys

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# SERP API Key  
SERP_API_KEY=your_serp_api_key_here

# Google OAuth credentials for email sending
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=your_redirect_uri_here

# Firebase credentials (optional if using service account JSON file)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_firebase_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Alternative: Path to Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json
